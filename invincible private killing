local function FormatDisplay(value)
    local normal = tostring(value):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    local abbreviations = {"", "K", "M", "B", "T", "Qa", "Qi"}
    local num, i = value, 1
    while num >= 1000 do
        num = num / 1000
        i = i + 1
    end
    local abbr = string.format("%.2f", num) .. abbreviations[i]
    return "[ " .. normal .. " | " .. abbr .. " ]"
end

