-- Advanced Stats Logic
local function calculateEnemyHealth(target)
    if not target then return 0 end
    local base = target:FindFirstChild("Durability") and target.Durability.Value or 0
    local mult = 1
    if target:FindFirstChild("ultimatesFolder") and target.ultimatesFolder:FindFirstChild("Infernal Health") then
        mult = mult + 0.15 * (target.ultimatesFolder["Infernal Health"].Value or 0)
    end
    return base * mult
end

local function calculateLocalPlayerDamage()
    local str = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Strength")
    if not str then return 0 end
    local base = str.Value * 0.0667
    local mult = 1
    if LocalPlayer:FindFirstChild("ultimatesFolder") and LocalPlayer.ultimatesFolder:FindFirstChild("Demon Damage") then
        mult = mult + math.min(0.1 * LocalPlayer.ultimatesFolder["Demon Damage"].Value, 0.5)
    end
    return base * mult
end

local function calculateHitsToKill(health, damage)
    if damage <= 0 then return "∞" end
    local hits = math.ceil(health / damage)
    return hits > 50 and "∞" or hits
end

task.spawn(function()
    while task.wait(0.3) do
        local target = Players:FindFirstChild(SelectPlayerName)
        if target then
            local health = calculateEnemyHealth(target)
            local dmg = calculateLocalPlayerDamage()
            local hits = calculateHitsToKill(health, dmg)
            enemyHealthLabel.Text = "Enemy Health: " .. FormatDisplay(health)
            playerDamageLabel.Text = "Your Damage: " .. FormatDisplay(dmg)
            hitsToKillLabel.Text = "Hits to Kill: " .. tostring(hits)
        else
            enemyHealthLabel.Text = "Enemy Health: N/A"
            playerDamageLabel.Text = "Your Damage: N/A"
            hitsToKillLabel.Text = "Hits to Kill: N/A"
        end
    end
end)

