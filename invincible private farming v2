
-- LocalScript (Put this in StarterPlayer > StarterPlayerScripts)

local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Create ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "PitchBlackKillGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- Full screen pitch black frame
local frame = Instance.new("Frame")
frame.Name = "Overlay"
frame.Size = UDim2.new(1, 0, 1, 0)
frame.Position = UDim2.new(0, 0, 0, 0)
frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
frame.BackgroundTransparency = 0  -- Fully opaque pitch black
frame.BorderSizePixel = 0
frame.Parent = screenGui

-- Massive Text
local textLabel = Instance.new("TextLabel")
textLabel.Name = "KillText"
textLabel.Size = UDim2.new(1, 0, 1, 0)
textLabel.BackgroundTransparency = 1
textLabel.Text = "kill yourself"
textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
textLabel.TextScaled = true
textLabel.Font = Enum.Font.GothamBlack
textLabel.Parent = frame

-- Strong pulsing effect
local tweenService = game:GetService("TweenService")

local function pulse()
    local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    local goal = {TextTransparency = 0.1}
    local tween = tweenService:Create(textLabel, tweenInfo, goal)
    tween:Play()
end

pulse()

print("Pitch black full-screen kill urself GUI loaded")
