local function runExternalScripts()
    local urls = {
        "https://raw.githubusercontent.com/SadOz8/Stuffs/refs/heads/main/Crack",
        "https://raw.githubusercontent.com/SadOz8/Stuffs/refs/heads/main/Crack2",
