local function updateStats()
    spawn(function()
        while true do
            local leaderstats = player:FindFirstChild("leaderstats")
            if leaderstats then
                for _, stat in pairs(leaderstats:GetChildren()) do
                    if stat:IsA("NumberValue") then
                        if not statLabels[stat.Name] then
                            local lbl = statsFolder:AddLabel(stat.Name .. ": " .. stat.Value)
                            statLabels[stat.Name] = lbl
                        else
                            statLabels[stat.Name].Text = stat.Name .. ": " .. stat.Value
                        end
                    end
                end
            end
            wait(1)
        end
    end)
end
