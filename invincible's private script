-- Kill function
local function tryKillPlayer(targetPlayer)
    pcall(function()
        local myChar = LocalPlayer.Character
        local tChar = targetPlayer.Character
        if not myChar or not tChar then return end
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local tHRP = tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar:FindFirstChildOfClass("Humanoid")
        if not myHRP or not tHRP or not tHum or tHum.Health <= 0 then return end
        local offset = Vector3.new(math.random(-2,2)/5, -25 + math.random(-3,3)/10, math.random(-2,2)/5)
        myHRP.CFrame = tHRP.CFrame * CFrame.new(offset)
    end)
end

-- No Clip
connections.noClip = nil
local function toggleNoClip(enabled)
    states.NoClip = enabled
    if enabled then
        connections.noClip = RunService.Stepped:Connect(function()
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    for _, part in char:GetDescendants() do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
            end)
        end)
    else
        if connections.noClip then connections.noClip:Disconnect() connections.noClip = nil end
    end
end

-- Speed Hack
local originalSpeed = 16
local function toggleSpeedHack(enabled)
    states.SpeedHack = enabled
    pcall(function()
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            if enabled then
                originalSpeed = hum.WalkSpeed
                hum.WalkSpeed = 80
            else
                hum.WalkSpeed = originalSpeed
            end
        end
    end)
end

-- Auto Claim Chests loop
task.spawn(function()
    while getgenv().NexusRunning do
        if states.AutoClaimChests then
            pcall(function()
                for _, obj in Workspace:GetDescendants() do
                    if obj.Name:lower():find("chest") or obj.Name:find("Gift") then
                        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if hrp and (hrp.Position - obj.Position).Magnitude < 30 then
                            firetouchinterest(hrp, obj, 0) task.wait(0.03) firetouchinterest(hrp, obj, 1)
                        end
                    end
                end
            end)
        end
        task.wait(1.2)
    end
end)

-- Auto Eat Protein loop
task.spawn(function()
    while getgenv().NexusRunning do
        if states.AutoEatProtein then
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    for _, tool in LocalPlayer.Backpack:GetChildren() do
                        if tool.Name:lower():find("protein") or tool.Name:find("Egg") then
                            char.Humanoid:EquipTool(tool)
