-- Rock Farm
-- ────────────────────────────────────────
task.spawn(function()
    while getgenv().NexusRunning do
        if not rockFarmActive or selectedRockDur <= 0 then
            task.wait(0.8) continue
        end
        pcall(function()
            local char = LocalPlayer.Character
            if not char or char.Humanoid.Health <= 0 then task.wait(1.5) return end
            local dur = LocalPlayer:FindFirstChild("Durability")
            if not dur or dur.Value < selectedRockDur then task.wait(0.6) return end

            safeEquipTool("Punch")

            for _, obj in ipairs(Workspace.machinesFolder:GetDescendants()) do
                if obj.Name == "neededDurability" and obj:IsA("IntValue") and obj.Value == selectedRockDur then
                    local rock = obj.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        local rh = char:FindFirstChild("RightHand")
                        local lh = char:FindFirstChild("LeftHand")
                        if rh then firetouchinterest(rock, rh, 0) task.wait(0.02) firetouchinterest(rock, rh, 1) end
                        if lh then firetouchinterest(rock, lh, 0) task.wait(0.02) firetouchinterest(rock, lh, 1) end
                        if muscleEvent then
                            muscleEvent:FireServer("punch", "leftHand")
                            muscleEvent:FireServer("punch", "rightHand")
                        end
                    end
                end
            end
        end)
        task.wait(0.18)
    end
end)

local function toggleRockFarm(dur, enabled)
    if enabled then
        selectedRockDur = dur
        rockFarmActive = true
    elseif selectedRockDur == dur then
        rockFarmActive = false
        selectedRockDur = 0
    end
end

