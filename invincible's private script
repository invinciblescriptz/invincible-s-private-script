-- Rock farm loop
task.spawn(function()
    while getgenv().NexusRunning do
        if not rockFarm.active or rockFarm.durability <= 0 then
            task.wait(1) continue
        end
        pcall(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                task.wait(1.5) return
            end
            local dur = LocalPlayer:FindFirstChild("Durability")
            if not dur or dur.Value < rockFarm.durability then
                task.wait(0.8) return
            end
            safeEquip("Punch")
            for _, obj in Workspace.machinesFolder:GetDescendants() do
                if obj.Name == "neededDurability" and obj:IsA("IntValue") and obj.Value == rockFarm.durability then
                    local rock = obj.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        local rh = char:FindFirstChild("RightHand")
                        local lh = char:FindFirstChild("LeftHand")
                        if rh then
                            firetouchinterest(rock, rh, 0) task.wait(0.025) firetouchinterest(rock, rh, 1)
                        end
                        if lh then
                            firetouchinterest(rock, lh, 0) task.wait(0.025) firetouchinterest(rock, lh, 1)
                        end
                        if muscleEvent then
                            muscleEvent:FireServer("punch", "leftHand")
                            muscleEvent:FireServer("punch", "rightHand")
                        end
                    end
                end
            end
        end)
        task.wait(0.22)
    end
end)

