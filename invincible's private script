-- Safe teleport function
local function tpTo(position)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(position)
        end
    end)
end

-- Safe tool equip + rep
local function startAutoRep(toolName, stateKey)
    task.spawn(function()
        while states[stateKey] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                    task.wait(2) return
                end

                local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
                if tool and tool.Parent ~= char then
                    char.Humanoid:EquipTool(tool)
                end

                if muscleEvent then
                    muscleEvent:FireServer("rep")
                end
            end)
            task.wait(0.07)
        end
        -- cleanup
        pcall(function()
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChild(toolName)
            if tool then tool.Parent = LocalPlayer.Backpack end
        end)
    end)
end

-- Fast strength / punch loop
local fastLoopConn
local function toggleFastLoop(state, usePunch)
    if fastLoopConn then fastLoopConn:Disconnect() fastLoopConn = nil end
    if not state then return end

    fastLoopConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if muscleEvent then
                if usePunch then
                    muscleEvent:FireServer("punch", "rightHand")
                    muscleEvent:FireServer("punch", "leftHand")
                else
                    muscleEvent:FireServer("rep")
                end
            end

            local char = LocalPlayer.Character
            if char then
                local tool = char:FindFirstChildWhichIsA("Tool")
                if tool then tool:Activate() end
            end
        end)
    end)
end

-- Infinite jump
local jumpConn
local function toggleInfiniteJump(state)
    if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    if not state then return end

    jumpConn = UserInputService.JumpRequest:Connect(function()
        pcall(function()
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum:ChangeState("Jumping") end
        end)
    end)
end

-- Anti-AFK
