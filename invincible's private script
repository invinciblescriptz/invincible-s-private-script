-- ESP
local espHighlights = {}
local function toggleESP(enabled)
    states.ESP = enabled
    if enabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(255, 40, 40)
                hl.OutlineColor = Color3.fromRGB(255, 220, 0)
                hl.FillTransparency = 0.45
                hl.OutlineTransparency = 0
                hl.Parent = plr.Character
                espHighlights[plr] = hl
            end
        end
        connections.espAdded = Players.PlayerAdded:Connect(function(plr)
            plr.CharacterAdded:Connect(function(char)
                if states.ESP then
                    local hl = Instance.new("Highlight")
                    hl.FillColor = Color3.fromRGB(255, 40, 40)
                    hl.OutlineColor = Color3.fromRGB(255, 220, 0)
                    hl.FillTransparency = 0.45
                    hl.OutlineTransparency = 0
                    hl.Parent = char
                    espHighlights[plr] = hl
                end
            end)
        end)
    else
        for _, hl in pairs(espHighlights) do pcall(function() hl:Destroy() end) end
        espHighlights = {}
        if connections.espAdded then connections.espAdded:Disconnect() end
    end
end

