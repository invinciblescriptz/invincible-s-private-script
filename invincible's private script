-- Improved remote finder (2026 era – more paths & names)
local function findRemote(patterns)
    for _, cont in {ReplicatedStorage, game} do
        for _, name in ipairs(patterns) do
            local found = cont:FindFirstChild(name, true)
            if found and (found:IsA("RemoteEvent") or found:IsA("RemoteFunction")) then
                return found
            end
        end
    end
    return nil
end

