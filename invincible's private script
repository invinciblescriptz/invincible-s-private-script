-- =============================================================
-- Improved Kill functions (fixed version)
-- =============================================================
local function tryKillPlayer(targetPlayer)
    pcall(function()
        local myChar = LocalPlayer.Character
        local tChar  = targetPlayer.Character
        if not myChar or not tChar then return end
        
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local tHRP  = tChar:FindFirstChild("HumanoidRootPart")
        local tHum  = tChar:FindFirstChildOfClass("Humanoid")
        
        if not myHRP or not tHRP or not tHum or tHum.Health <= 0 then return end
        
        -- Small random offset to make it less obvious/detectable
        local offset = Vector3.new(math.random(-2,2)/5, -25 + math.random(-3,3)/10, math.random(-2,2)/5)
        myHRP.CFrame = tHRP.CFrame * CFrame.new(offset)
        
        -- Optional: tiny punch trigger (uncomment if needed for your server)
        -- if muscleEvent then muscleEvent:FireServer("punch", "rightHand") end
    end)
end

