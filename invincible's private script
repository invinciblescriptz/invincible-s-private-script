local function equipBestPet()
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") then return end
        local highestStat = 0
        bestPet = nil
        for _, pet in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if pet:IsA("Tool") and (pet.Name:lower():find("pet") or pet:FindFirstChild("Multiplier") or pet:FindFirstChild("Strength")) then
                local mult = (pet:FindFirstChild("Multiplier") and pet.Multiplier.Value) or 1
                if mult > highestStat then
                    highestStat = mult
                    bestPet = pet
                end
            end
        end
        if bestPet then
            char.Humanoid:EquipTool(bestPet)
        end
    end)
end
