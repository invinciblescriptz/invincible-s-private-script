-- Helpers
local function tpTo(pos)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(pos) end
    end)
end

local function safeEquip(toolName)
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") then return end
        local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
        if tool and tool.Parent ~= char then char.Humanoid:EquipTool(tool) end
    end)
end

local function safeUnequip(toolName)
    pcall(function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild(toolName) then char[toolName].Parent = LocalPlayer.Backpack end
    end)
end

local function startAutoRep(toolName, stateKey)
    task.spawn(function()
        while states[stateKey] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then task.wait(1.8) return end
                safeEquip(toolName)
                if muscleEvent then muscleEvent:FireServer("rep") end
            end)
            task.wait(0.14 + math.random(0, 8)/100) -- slight randomization vs detection
        end
        safeUnequip(toolName)
    end)
end

-- Fast Strength (on Heartbeat – throttled internally)
connections.fastStrength = nil
local function toggleFastStrength(enabled)
    states.FastStrength = enabled
    if enabled then
        if connections.fastStrength then connections.fastStrength:Disconnect() end
        connections.fastStrength = RunService.Heartbeat:Connect(function()
            if not states.FastStrength then return end
            pcall(function()
                if muscleEvent then
                    muscleEvent:FireServer("rep")
                    muscleEvent:FireServer("punch", "rightHand")
                    muscleEvent:FireServer("punch", "leftHand")
                end
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildWhichIsA("Tool")
                    if tool then tool:Activate() end
                end
            end)
        end)
    else
        if connections.fastStrength then connections.fastStrength:Disconnect() connections.fastStrength = nil end
    end
end

