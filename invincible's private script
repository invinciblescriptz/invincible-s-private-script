-- Stats Spy & Dynamic Updates
local statLabels = {}
local statsFolder = specsTab:AddFolder("My Stats")
local function addOrUpdateStatLabel(name, value)
    local labelName = name .. ": "
    if not statLabels[name] then
        local lbl = statsFolder:AddLabel(labelName .. tostring(value))
        lbl.TextSize = 16
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        statLabels[name] = lbl
    else
        statLabels[name].Text = labelName .. tostring(value)
    end
end

task.spawn(function()
    while getgenv().NexusRunning do
        pcall(function()
            local lp = game.Players.LocalPlayer
            local leaderstats = lp:FindFirstChild("leaderstats")
            if leaderstats then
                for _, stat in ipairs(leaderstats:GetChildren()) do
                    if stat:IsA("IntValue") or stat:IsA("NumberValue") then
                        addOrUpdateStatLabel(stat.Name, stat.Value)
                    end
                end
            end
            local durability = lp:FindFirstChild("Durability")
            if durability and durability:IsA("IntValue") then
                addOrUpdateStatLabel("Durability", durability.Value)
            end
            local strength = lp:FindFirstChild("Strength") or (leaderstats and leaderstats:FindFirstChild("Strength"))
            if strength and (strength:IsA("IntValue") or strength:IsA("NumberValue")) then
                addOrUpdateStatLabel("Strength", strength.Value)
            end
            local owned = lp:FindFirstChild("ownedGamepasses")
            if owned then
                addOrUpdateStatLabel("Gamepasses Owned", #owned:GetChildren())
            end
            local currentArea = lp:FindFirstChild("CurrentArea") or lp:FindFirstChild("Zone")
            if currentArea and currentArea:IsA("StringValue") then
                addOrUpdateStatLabel("Area", currentArea.Value)
            end
        end)
        task.wait(1.4)
    end
    -- Cleanup
    for _, lbl in pairs(statLabels) do
        pcall(function() lbl:Destroy() end)
    end
end)

-- Lock Position / Rebirth Control in Farming tab
local lockEnabled = false
local function stopLock()
    if lockConn then lockConn:Disconnect() lockConn = nil end
    local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if r then r.Anchored = false end
end
local function startLock()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local currentPos = root.CFrame
    root.Anchored = true
    lockConn = RunService.Heartbeat:Connect(function()
        local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if r then
            r.Anchored = true
            r.CFrame = currentPos
        end
    end)
end
local function updatePosLock(state)
    lockEnabled = state
    if state then startLock() else stopLock() end
end

local lockButton = farmingTab:AddButton("Lock Position", function()
    updatePosLock(not lockEnabled)
    if lockEnabled then
        lockButton:SetText("Unlock")
    else
        lockButton:SetText("Lock")
    end
end)

-- Auto-follow Player
local followTarget, following = nil, false
local function followPlayer(target)
    local myChar = LocalPlayer.Character
    local targetChar = target.Character
    if not (myChar and targetChar) then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if myHRP and targetHRP then
        local followPos = targetHRP.Position - (targetHRP.CFrame.LookVector * 3)
        myHRP.CFrame = CFrame.new(followPos, targetHRP.Position)
    end
end

local followDropdown = killerTab:AddDropdown("Follow Player", function(selectedDisplayName)
    if selectedDisplayName and selectedDisplayName ~= "" then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.DisplayName == selectedDisplayName then
                followTarget = plr
                following = true
                print("✅ Started following:", plr.Name)
                followPlayer(plr)
                break
            end
        end
    end
end)

-- Populate dropdown
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        followDropdown:Add(player.DisplayName)
    end
end
-- Update list when players join/leave
Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        followDropdown:Add(player.DisplayName)
    end
end)
Players.PlayerRemoving:Connect(function(player)
    -- Refresh list
    followDropdown:Clear()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            followDropdown:Add(plr.DisplayName)
        end
    end
    -- Stop following if target leaves
    if followTarget and followTarget.Name == player.Name then
        followTarget = nil
        following = false
    end
end)

local function followLoop()
    while true do
        if following and followTarget then
            local target = Players:FindFirstChild(followTarget.Name)
            if target then
                followPlayer(target)
            else
                following = false
            end
        end
        task.wait(0.01)
    end
end
task.spawn(followLoop)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    if following and followTarget then
        local target = Players:FindFirstChild(followTarget.Name)
        if target then
            followPlayer(target)
        end
    end
end)

