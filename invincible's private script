-- Killer Tab - IMPROVED
killerTab:AddSwitch("Kill Aura (All)", function(s)
    states.KillAura = s
    if s then
        task.spawn(function()
            while states.KillAura and getgenv().NexusRunning do
                local count = 0
                for _, plr in Players:GetPlayers() do
                    if plr ~= LocalPlayer and plr.Character then
                        tryKillPlayer(plr)
                        count += 1
                        if count >= 6 then break end  -- limit per cycle
                    end
                end
                task.wait(0.22 + math.random(1,8)/100)  -- jitter 0.22-0.30s
            end
        end)
    end
end)

