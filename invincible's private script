-- Rock Farm (exclusive – one at a time)
task.spawn(function()
    while getgenv().NexusRunning do
        if rockFarm.active and rockFarm.durability > 0 then
            pcall(function()
                local char = LocalPlayer.Character
                if not char or char.Humanoid.Health <= 0 then jitterWait(2.2) return end
                
                local durVal = LocalPlayer:FindFirstChild("Durability")
                if not durVal or durVal.Value < rockFarm.durability then jitterWait(1.2) return end
                
                safeEquip("Punch")
                local rock = rockCache[rockFarm.durability]
                if rock and rock.Parent then
                    local rh = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
                    if rh then
                        firetouchinterest(rock, rh, 0)
                        task.wait(0.04)
                        firetouchinterest(rock, rh, 1)
                    end
                    if muscleEvent then muscleEvent:FireServer("punch", "rightHand") end
                end
            end)
        end
        jitterWait(0.38)
    end
end)

