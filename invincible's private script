                if goldenRebirth then
                    local val = goldenRebirth.Value
                    rebirthCount = math.floor(rebirthCount * (1 - val * 0.1))
                end

                -- Rebirth
                game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                task.wait(0.1)

                -- Unequip pets, then equip specific pets
                local petsFolder = _LocalPlayer:FindFirstChild("petsFolder")
                if petsFolder then
                    for _, v in pairs(petsFolder:GetChildren()) do
                        if v:IsA("Folder") then
                            for _, pet in pairs(v:GetChildren()) do
                                _ReplicatedStorage.rEvents.equipPetEvent:FireServer('unequipPet', pet)
                            end
                        end
                    end
                end

                -- Equip specific pets
                local function equipSpecificPet(name)
                    if petsFolder then
                        for _, v in pairs(petsFolder:GetChildren()) do
                            if v.Name == "Unique" then
                                for _, pet in pairs(v:GetChildren()) do
                                    if pet.Name == name then
                                        _ReplicatedStorage.rEvents.equipPetEvent:FireServer('equipPet', pet)
                                    end
                                end
                            end
                        end
                    end
                end

                equipSpecificPet('Swift Samurai')
                -- Wait for strength to reach rebirth count
                while _LocalPlayer.leaderstats and _LocalPlayer.leaderstats.Strength and _LocalPlayer.leaderstats.Strength.Value < rebirthCount do
                    _LocalPlayer.muscleEvent:FireServer('rep')
                    task.wait()
                end

                -- Equip another pet
                equipSpecificPet('Tribal Overlord')

                -- Find Jungle Bar Lift
                local jungleLift = findMachine('Jungle Bar Lift')
                if jungleLift and jungleLift:FindFirstChild('interactSeat') then
                    _LocalPlayer.Character.HumanoidRootPart.CFrame = jungleLift.interactSeat.CFrame * CFrame.new(0, 3, 0)
                    repeat
                        task.wait(0.1)
                        pressKey('E')
                    until _LocalPlayer.Character.Humanoid.Sit
                end

                -- Rebirth Loop
                repeat
                    game:GetService("ReplicatedStorage").rEvents.rebirthRemote:InvokeServer('rebirthRequest')
                    task.wait(0.1)
                until _LocalPlayer.leaderstats.Rebirths and _LocalPlayer.leaderstats.Rebirths.Value >= rebirthCount

                task.wait()
            end

        end)
    end
end
