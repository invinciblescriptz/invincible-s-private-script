local function toggleAutoRespawn(state)
    states.AutoRespawn = state
    if state then
        if respawnConn then return end
        respawnConn = game:GetService("Players").Player.CharacterAdded:Connect(function()
            print("Respawned.")
        end)
        -- Detect death
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.Died:Connect(function()
                print("Died, respawning in 2 seconds...")
                wait(2)
                if getgenv().NexusRunning then
                    -- Respawn by resetting character
                    LocalPlayer.Character = nil
                end
            end)
        end
        print("Auto Respawn enabled.")
    else
        if respawnConn then respawnConn:Disconnect() respawnConn = nil end
        print("Auto Respawn disabled.")
    end
end

