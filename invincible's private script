-- Create Parts for Water Walk
local parts = {}
local createdParts = false

local function createParts()
    local partsList = {}
    local partSize = 2048
    local totalDistance = 50000
    local startPos = Vector3.new(-2, -9.5, -2)
    local num = math.ceil(totalDistance / partSize)
    for x=0, num-1 do
        for z=0, num-1 do
            local p1 = Instance.new("Part")
            p1.Size = Vector3.new(partSize, 1, partSize)
            p1.Position = startPos + Vector3.new(x*partSize,0,z*partSize)
            p1.Anchored = true
            p1.Transparency = 1
            p1.CanCollide = true
            p1.Name = "Part_Side_"..x.."_"..z
            p1.Parent = workspace
            table.insert(partsList, p1)
            local p2 = Instance.new("Part")
            p2.Size = Vector3.new(partSize, 1, partSize)
            p2.Position = startPos + Vector3.new(-x*partSize,0,z*partSize)
            p2.Anchored = true
            p2.Transparency = 1
            p2.CanCollide = true
            p2.Name = "Part_LeftRight_"..x.."_"..z
            p2.Parent = workspace
            table.insert(partsList, p2)
            local p3 = Instance.new("Part")
            p3.Size = Vector3.new(partSize, 1, partSize)
            p3.Position = startPos + Vector3.new(-x*partSize,0,-z*partSize)
            p3.Anchored = true
            p3.Transparency = 1
            p3.CanCollide = true
            p3.Name = "Part_UpLeft_"..x.."_"..z
            p3.Parent = workspace
            table.insert(partsList, p3)
            local p4 = Instance.new("Part")
            p4.Size = Vector3.new(partSize, 1, partSize)
            p4.Position = startPos + Vector3.new(x*partSize,0,-z*partSize)
            p4.Anchored = true
            p4.Transparency = 1
            p4.CanCollide = true
            p4.Name = "Part_UpRight_"..x.."_"..z
            p4.Parent = workspace
            table.insert(partsList, p4)
        end
    end
    return partsList
end

local function makePartsWalkthrough(partsTable)
    for _, part in ipairs(partsTable) do
        if part and part.Parent then
            part.CanCollide = false
        end
    end
end

local function makePartsSolid(partsTable)
    for _, part in ipairs(partsTable) do
        if part and part.Parent then
            part.CanCollide = true
        end
    end
end

local function toggleWaterWalk(enable)
    if enable then
        if not createdParts then
            parts = createParts()
            createdParts = true
        end
        makePartsWalkthrough(parts)
    else
        makePartsSolid(parts)
    end
end

