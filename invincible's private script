local farmRunning = false
local repSpeed = 350
local pingControl = true
local networkStats = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]
local function getCurrentPing()
    return networkStats:GetValue()
end

local function getAdaptiveSpeed(ping)
    if ping < 80 then
        return 500
    elseif ping < 150 then
        return 300
    elseif ping < 250 then
        return 100
    else
        return 50
    end
end

local function startAutoRep()
    local lastPing = tick()
    local currentPing = getCurrentPing()
    while farmRunning do
        if tick() - lastPing > 0.5 then
            currentPing = getCurrentPing()
            lastPing = tick()
        end
        local reps = pingControl and getAdaptiveSpeed(currentPing) or repSpeed
        local delay = math.clamp(currentPing / 2500, 0.001, 0.1)
        for i=1, math.min(reps, repSpeed) do
            game:GetService("Players").LocalPlayer.muscleEvent:FireServer("rep")
            if i % 500 == 0 then task.wait(0) end
        end
        task.wait(delay)
    end
end

