-- Helpers
local function tpTo(position)
    pcall(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(position) end
    end)
end

local function safeEquipTool(toolName)
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") then return end
        local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
        if tool and tool.Parent ~= char then
            char.Humanoid:EquipTool(tool)
        end
    end)
end

local function autoRepLoop(toolName, stateKey)
    task.spawn(function()
        while states[stateKey] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                if not char or char.Humanoid.Health <= 0 then task.wait(1.8) return end
                safeEquipTool(toolName)
                if muscleEvent then muscleEvent:FireServer("rep") end
            end)
            task.wait(0.07)
        end
        pcall(function()
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChild(toolName)
            if tool then tool.Parent = LocalPlayer.Backpack end
        end)
    end)
end

-- Improved kill function (range + offset + whitelist)
local function improvedKill(target)
    pcall(function()
        local me   = LocalPlayer.Character
        local them = target.Character
        if not (me and them) then return end

        local myHRP    = me:FindFirstChild("HumanoidRootPart")
        local theirHRP = them:FindFirstChild("HumanoidRootPart")
        local theirHum = them:FindFirstChildOfClass("Humanoid")

        if myHRP and theirHRP and theirHum and theirHum.Health > 0 then
            local distance = (myHRP.Position - theirHRP.Position).Magnitude
            if distance > killRange then return end

            myHRP.CFrame = theirHRP.CFrame * CFrame.new(0, killOffset, 0)
        end
    end)
end

