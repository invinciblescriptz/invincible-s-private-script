-- Improved Kill Player (equip punch, face target, spam punch events + activate)
local function killPlayer(target)
    pcall(function()
        local myChar = LocalPlayer.Character
        local tChar = target.Character
        if not myChar or not tChar or tChar.Humanoid.Health <= 0 then return end

        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local tHRP = tChar:FindFirstChild("HumanoidRootPart")
        if not myHRP or not tHRP then return end

        -- Position to hit (close + facing)
        myHRP.CFrame = tHRP.CFrame * CFrame.new(0, 0, -2) * CFrame.Angles(0, math.pi, 0)

        equipTool("Punch")

        if muscleEvent then
            muscleEvent:FireServer("punch", "rightHand")
            muscleEvent:FireServer("punch", "leftHand")
        end

        local punchTool = myChar:FindFirstChild("Punch")
        if punchTool then
            local atk = punchTool:FindFirstChild("attackTime")
            if atk and atk:IsA("NumberValue") then atk.Value = 0.01 end
            punchTool:Activate()
        end
    end)
end

