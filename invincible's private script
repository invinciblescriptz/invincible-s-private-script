-- Helper functions
local function tpTo(pos)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.new(pos) end
end

local function safeEquipTool(name)
    pcall(function()
        local char = player.Character
        if not char then return end
        local hr = char:FindFirstChild("Humanoid")
        local backpack = player.Backpack
        local tool = backpack:FindFirstChild(name) or char:FindFirstChild(name)
        if tool and tool.Parent ~= char then
            hr:EquipTool(tool)
        end
    end)
end

local function fireServer(key)
    pcall(function()
        if muscleEvent then muscleEvent:FireServer(key) end
    end)
end

local function toggleAutoRep(toolName, key)
    boolStates[toolName] = true
    task.spawn(function()
        while boolStates[toolName] do
            local char = player.Character
            if not char or char.Humanoid.Health <= 0 then wait(1.5) continue end
            safeEquipTool(toolName)
            fireServer(key)
            wait(0.09)
        end
    end)
end

local function stopAutoRep(toolName)
    boolStates[toolName] = false
end

local function toggleInfiniteJump(state)
    boolStates.InfiniteJump = state
    if state then
        if jumpConn then return end
        jumpConn = UserInputService.JumpRequest:Connect(function()
            pcall(function()
                local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        end)
    else
        if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    end
end

local function toggleAntiAFK(state)
    boolStates.AntiAFK = state
    if state then
        if antiAfkConn then return end
        antiAfkConn = player.Idled:Connect(function()
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end)
    else
        if antiAfkConn then antiAfkConn:Disconnect() end
    end
end

local function killTarget(target)
    pcall(function()
        local tchar = target.Character
        local mychar = player.Character
        if not tchar or not mychar then return end
        local tHRP = tchar:FindFirstChild("HumanoidRootPart")
        local myHRP = mychar:FindFirstChild("HumanoidRootPart")
        if tHRP and myHRP then
            myHRP.CFrame = tHRP.CFrame * CFrame.new(0, -25, 0)
        end
    end)
end

local function findClosestPlayer(input)
    if not input or input == "" then return nil end
    input = input:lower()
    local best, score = nil, 0
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            local name = plr.Name:lower()
            local display = (plr.DisplayName or ""):lower()
            local s = 0
            if name:find(input) then s = s + 50 end
            if display:find(input) then s = s + 50 end
            if s > score then score = s; best = plr end
        end
    end
    if score > 20 then return best end
end

