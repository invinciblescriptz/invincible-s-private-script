        0.228692636, 5.38890532e-08, 0.973498702,
        9.52623491e-09, 1, -5.75939509e-08,
        -0.973498702, 2.24450893e-08, 0.228692636
    )

    -- Cleanup old connection
    if _G.NaNLockConnection then
        _G.NaNLockConnection:Disconnect()
        _G.NaNLockConnection = nil
    end

    if state then
        -- === TURNED ON ===
        
        -- NaN size
        local args = {"changeSize", 0/0}
        game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("changeSpeedSizeRemote"):InvokeServer(unpack(args))

        -- Function to apply teleport + lock
        local function applyLock(character)
            if not character then return end
            local root = character:WaitForChild("HumanoidRootPart", 5)
            if not root then return end

            root.CFrame = targetCFrame
            root.Anchored = true
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)

            -- Strong continuous lock
            if _G.NaNLockConnection then
                _G.NaNLockConnection:Disconnect()
            end

            _G.NaNLockConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if root and root.Parent then
                    root.CFrame = targetCFrame
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end)
        end

        -- Apply to current character
        local character = player.Character or player.CharacterAdded:Wait()
        applyLock(character)

        -- Auto re-apply on respawn
        if not _G.NaNCharacterAddedConn then
            _G.NaNCharacterAddedConn = player.CharacterAdded:Connect(function(newChar)
                task.wait(0.1) -- small delay to let character fully load
                applyLock(newChar)
            end)
        end

    else
        -- === TURNED OFF ===
        local character = player.Character
        if character then
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                root.Anchored = false
                root.Velocity = Vector3.new(0, 5, 0)
            end
        end

        -- Clean up connections
        if _G.NaNLockConnection then
            _G.NaNLockConnection:Disconnect()
            _G.NaNLockConnection = nil
        end

        if _G.NaNCharacterAddedConn then
            _G.NaNCharacterAddedConn:Disconnect()
            _G.NaNCharacterAddedConn = nil
        end
    end
