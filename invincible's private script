            local _ReplicatedStorage = game:GetService('ReplicatedStorage')
            local _LocalPlayer = game:GetService('Players').LocalPlayer

            local function unequipPets()
                local petsFolder = _LocalPlayer:FindFirstChild("petsFolder")
                if not petsFolder then return end
                for _, v in pairs(petsFolder:GetChildren()) do
                    if v:IsA("Folder") then
                        for _, pet in pairs(v:GetChildren()) do
                            if pet then
                                _ReplicatedStorage.rEvents.equipPetEvent:FireServer('unequipPet', pet)
                            end
                        end
                    end
                end
                task.wait(0.1)
            end

            local function equipPet(petName)
                unequipPets()
                task.wait(0.01)
                local pets = _LocalPlayer:FindFirstChild("petsFolder")
                if not pets then return end
                for _, pet in pairs(pets:GetChildren()) do
                    if pet.Name == petName then
                        _ReplicatedStorage.rEvents.equipPetEvent:FireServer('equipPet', pet)
                    end
                end
            end

            local function findMachine(name)
                local machine
                local function scanFolder(folder)
                    for _, v in pairs(folder:GetChildren()) do
                        if v.Name == name then
                            machine = v
                            break
                        end
                        if v:IsA("Folder") then
                            scanFolder(v)
                        end
                    end
