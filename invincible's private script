        sessionTimerLabel.Text = "Session Time: " .. formatTime(sessionTime)
    end

    local strength   = leaderstats and leaderstats:FindFirstChild("Strength")   and leaderstats.Strength.Value   or 0
    local rebirths   = leaderstats and leaderstats:FindFirstChild("Rebirths")   and leaderstats.Rebirths.Value   or 0
    local kills      = leaderstats and leaderstats:FindFirstChild("Kills")      and leaderstats.Kills.Value      or 0
    local brawls     = leaderstats and leaderstats:FindFirstChild("Brawls")     and leaderstats.Brawls.Value     or 0

    if leaderStatsLabel and leaderStatsLabel.Text then
        leaderStatsLabel.Text = string.format(
            "Strength: %s\nRebirths: %s\nKills: %s\nBrawls: %s",
            formatNumber(strength), formatNumber(rebirths), formatNumber(kills), formatNumber(brawls)
        )
    end

    local gKarma = goodKarma and goodKarma.Value or 0
    local eKarma = evilKarma and evilKarma.Value or 0
    local dur    = Durability  and Durability.Value  or 0
    local agi    = Agility     and Agility.Value     or 0
    local mkt    = muscleKingTime and muscleKingTime.Value or 0

    if intStatsLabel and intStatsLabel.Text then
        intStatsLabel.Text = string.format(
            "Good Karma: %s\nEvil Karma: %s\nDurability: %s\nAgility: %s\nMuscle King Time: %s",
            formatNumber(gKarma), formatNumber(eKarma), formatNumber(dur), formatNumber(agi), formatNumber(mkt)
        )
    end
end

