                        part.CanCollide = false
                    end
                end
            else
                if noclipLoop then
                    noclipLoop:Disconnect()
                end
            end
        end)
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "No-Clip Activated",
            Text = "You can now pass through objects",
            Duration = 0
        })
    end
end)

