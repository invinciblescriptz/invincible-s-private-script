-- Rock Farm
local function setRockFarm(dur, enable)
    if enable then
        selectedRockDurability = dur
        rockFarmActive = true
    else
        if selectedRockDurability == dur then
            rockFarmActive = false
            selectedRockDurability = 0
        end
    end
end

