-- Position Lock
local posLocked = false
local lockedPosition = nil

local function lockPosition()
    if not posLocked then return end
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local bp = rootPart:FindFirstChild("PositionLocker") or Instance.new("BodyPosition")
    bp.Name = "PositionLocker"
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.P = 100000
    bp.Position = lockedPosition
    bp.Parent = rootPart
end

local function unlockPosition()
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        local bp = rootPart:FindFirstChild("PositionLocker")
        if bp then bp:Destroy() end
    end
end

fastTab:AddSwitch("Lock Position", function(bool)
    posLocked = bool
    if bool then
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then lockedPosition = root.Position end
        lockPosition()
    else
        unlockPosition()
    end
end)

player.CharacterAdded:Connect(function(char)
    task.wait(1)
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if posLocked and root then
        lockedPosition = root.Position
        lockPosition()
    end
end)

task.spawn(function()
    while true do
        if posLocked then lockPosition() end
        task.wait(0.1)
    end
end)

