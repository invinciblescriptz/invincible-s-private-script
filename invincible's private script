-- Add Player to whitelist
local function addPlayerToWhitelist(name)
    local player = findClosestPlayer(name)
    if player then
        local info = player.Name .. " (" .. player.DisplayName .. ")"
        if not table.find(_G.whitelistedPlayers, info) then
            table.insert(_G.whitelistedPlayers, info)
            updateWhitelistedPlayersLabel()
        end
    end
end

-- Remove Player from whitelist
local function removePlayerFromWhitelist(name)
    local lowerName = name:lower()
    for i, info in ipairs(_G.whitelistedPlayers) do
        if info:lower():find(lowerName, 1, true) then
            table.remove(_G.whitelistedPlayers, i)
            updateWhitelistedPlayersLabel()
            return
        end
    end
    -- Try to find by player object
    local player = findClosestPlayer(name)
    if player then
        for i, info in ipairs(_G.whitelistedPlayers) do
            if info:find(player.Name, 1, true) then
                table.remove(_G.whitelistedPlayers, i)
                updateWhitelistedPlayersLabel()
                return
            end
        end
    end
end

