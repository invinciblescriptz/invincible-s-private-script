local function addOrUpdateStatLabel(name, value)
    if not statLabels[name] then
        local lbl = statsFolder:AddLabel(name .. ": " .. tostring(value))
        lbl.TextSize = 16
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        statLabels[name] = lbl
    else
        statLabels[name].Text = name .. ": " .. tostring(value)
    end
end

spawn(function()
