                    for i, v in pairs(game:GetService("Workspace").machinesFolder:GetDescendants()) do
                        if v.Name == "neededDurability" and v.Value == neededDurability and
                            game.Players.LocalPlayer.Character and
                            game.Players.LocalPlayer.Character:FindFirstChild("RightHand") and
                            game.Players.LocalPlayer.Character:FindFirstChild("LeftHand") then

                            firetouchinterest(v.Parent.Rock, game.Players.LocalPlayer.Character.RightHand, 0)
                            firetouchinterest(v.Parent.Rock, game.Players.LocalPlayer.Character.RightHand, 0.01)
                            firetouchinterest(v.Parent.Rock, game.Players.LocalPlayer.Character.LeftHand, 0)
                            firetouchinterest(v.Parent.Rock, game.Players.LocalPlayer.Character.LeftHand, 0.01)
                            gettool()
                        end
                    end
                end
            end
        end)
    end
end

