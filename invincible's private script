-- Rock Farm
local function toggleRock(dur, enable)
    if enable then
        rockFarm.durability = dur
        rockFarm.active = true
    else
        if rockFarm.durability == dur then
            rockFarm.active = false
            rockFarm.durability = 0
        end
    end
end

