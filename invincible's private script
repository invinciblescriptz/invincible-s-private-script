local function useOneEgg()
    local egg = game.Players.LocalPlayer.Backpack:FindFirstChild("Protein Egg")
    if egg then
        egg.Parent = game.Players.LocalPlayer.Character
        task.wait(0.01)
        local virtualInput = game:GetService("VirtualInputManager")
        virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        task.wait(0.01)
        virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        return true
    end
    return false
end

local function checkEggTimer()
    local boostFolder = game.Players.LocalPlayer:FindFirstChild("boostTimersFolder")
    if not boostFolder then return false end
    local eggTimer = boostFolder:FindFirstChild("Protein Egg")
    if not eggTimer or tonumber(eggTimer.Value) > 2 then
        return useOneEgg()
    end
    return true
end

