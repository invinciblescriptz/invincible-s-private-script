-- Load Wind GUI library
local Wind = loadstring(game:HttpGet("https://raw.githubusercontent.com/wind-libs/wind/main/wind.lua"))()

local window = Wind:Window("Anti-AFK with Timer")

local toggleAntiAFK = false
local timerDuration = 60 -- default timer in seconds
local timerLabel

-- Function to start Anti-AFK
local function startAntiAFK()
    toggleAntiAFK = true
    spawn(function()
        while toggleAntiAFK do
            -- Simulate key press to prevent AFK
            game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            wait(0.1)
            game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            wait(30) -- wait 30 seconds before next input
        end
    end)
end

-- Function to stop Anti-AFK
local function stopAntiAFK()
    toggleAntiAFK = false
end

-- Timer update function
local function updateTimer()
    local remaining = timerDuration
    while remaining > 0 do
        timerLabel.Text = "Timer: " .. remaining .. "s"
        wait(1)
        remaining = remaining - 1
    end
    timerLabel.Text = "Time's up!"
end

-- Button to start Anti-AFK
local startBtn = window:Button("Start Anti-AFK", startAntiAFK)
-- Button to stop Anti-AFK
local stopBtn = window:Button("Stop Anti-AFK", stopAntiAFK)

-- Slider to set timer
local timerSlider = window:Slider("Set Timer (seconds)", 10, 600, function(value)
    timerDuration = value
end)

-- Label to display timer
timerLabel = window:Label("Timer: 0s")

-- Button to run timer
local function runTimer()
    updateTimer()
end
local startTimerBtn = window:Button("Start Timer", runTimer)
