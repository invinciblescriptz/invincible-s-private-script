-- Load Wind UI (assuming you have the URL correct and Wind UI is accessible)
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/your-repo/wind-ui/main/main.lua"))()

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game.CoreGui

local Window = WindUI:CreateWindow({
    Name = "Anti-AFK with Timer",
    FolderToSave = nil
})

local MainTab = Window:CreateTab("Main")
local AntiAfkSection = MainTab:CreateSection("Anti-AFK & Timer")

-- Create timer display label
local TimerLabel = Instance.new("TextLabel")
TimerLabel.Parent = AntiAfkSection
TimerLabel.Size = UDim2.new(0, 250, 0, 50)
TimerLabel.Position = UDim2.new(0, 10, 0, 50)
TimerLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
TimerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TimerLabel.TextScaled = true
TimerLabel.Text = "Time Elapsed: 0s"

local startTime = 0
local timerRunning = false
local timerConnection

-- Function to start timer
local function startTimer()
    startTime = os.time()
    timerRunning = true
    -- Update timer every second
    timerConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if timerRunning then
            local elapsed = os.time() - startTime
            TimerLabel.Text = "Time Elapsed: " .. elapsed .. "s"
        end
    end)
end

-- Button to start timer
local startButton = AntiAfkSection:CreateButton("Start Timer")
startButton.MouseButton1Click:Connect(function()
    if not timerRunning then
        startTimer()
    end
end)

-- Anti-AFK mechanism
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    wait(0.2)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- Optional: Add a button to stop timer and disconnect Heartbeat
local stopButton = AntiAfkSection:CreateButton("Stop Timer")
stopButton.MouseButton1Click:Connect(function()
    if timerRunning then
        timerRunning = false
        if timerConnection then
            timerConnection:Disconnect()
            timerConnection = nil
        end
        TimerLabel.Text = "Timer Stopped"
    end
end)
