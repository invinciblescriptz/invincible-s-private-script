local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

-- Create GUI
local gui = Instance.new("ScreenGui")
gui.Name = "MyFeatureUI"
gui.ResetOnSpawn = false
gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 160, 0, 80)
frame.Position = UDim2.new(0.5, -80, 0.5, -40) -- Centered
frame.BackgroundColor3 = Color3.fromRGB(139, 0, 0)
frame.BorderSizePixel = 0
frame.Parent = gui

-- Make the frame draggable (support PC and Mobile)
local dragging = false
local dragStartPosition
local startPos

local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    -- Check if input is a mouse click or touch
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- Optional: ensure input started within frame bounds
        -- But for simplicity, we'll assume it does
        if input.Target == frame or (input.Position and frame.AbsolutePosition and frame.AbsoluteSize and 
           input.Position.x >= frame.AbsolutePosition.x and input.Position.x <= frame.AbsolutePosition.x + frame.AbsoluteSize.x and
           input.Position.y >= frame.AbsolutePosition.y and input.Position.y <= frame.AbsolutePosition.y + frame.AbsoluteSize.y) then
            dragging = true
            dragStartPosition = input.Position
            startPos = frame.Position
        end
    end
end

local function onInputChanged(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPosition
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end

local function onInputEnded(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end

UserInputService.InputBegan:Connect(onInputBegan)
UserInputService.InputChanged:Connect(onInputChanged)
UserInputService.InputEnded:Connect(onInputEnded)

