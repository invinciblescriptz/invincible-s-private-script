-- Variables
local afkTime = 0
local isActive = true

-- Best Anti-AFK method
LocalPlayer.Idled:Connect(function()
	if isActive then
		VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
		task.wait(0.1)
		VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	end
end)

-- Function to format time nicely (1s → 1m 23s → 2h 5m 12s → 1d 3h 45m)
local function formatTime(seconds)
	local days = math.floor(seconds / 86400)
	seconds = seconds % 86400
	local hours = math.floor(seconds / 3600)
	seconds = seconds % 3600
	local minutes = math.floor(seconds / 60)
	seconds = math.floor(seconds % 60)

	if days > 0 then
		return string.format("%dd %dh %dm %ds", days, hours, minutes, seconds)
	elseif hours > 0 then
		return string.format("%dh %dm %ds", hours, minutes, seconds)
	elseif minutes > 0 then
		return string.format("%dm %ds", minutes, seconds)
	else
		return string.format("%ds", seconds)
	end
end

-- Main timer loop
RunService.Heartbeat:Connect(function(deltaTime)
	if isActive then
		afkTime += deltaTime
		timerLabel.Text = "AFK Timer: " .. formatTime(afkTime)
	else
		afkTime = 0
		timerLabel.Text = "AFK Timer: 0s"
	end
end)

-- Toggle functionality
toggleButton.MouseButton1Click:Connect(function()
	isActive = not isActive
	
	if isActive then
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
		toggleButton.Text = "AFK Protection: ON"
	else
		toggleButton.BackgroundColor3 = Color3.fromRGB(139, 0, 0)
		toggleButton.Text = "AFK Protection: OFF"
	end
end)
