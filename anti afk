-- Create ScreenGui
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

-- Create Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 50)
frame.Position = UDim2.new(0, 10, 0, 10)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.Parent = ScreenGui

-- Create Label
local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 100, 0, 50)
label.Position = UDim2.new(0, 10, 0, 0)
label.BackgroundTransparency = 1
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.Text = "Anti-AFK"
label.Font = Enum.Font.SourceSansBold
label.TextSize = 20
label.Parent = frame

-- Create Button
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 80, 0, 50)
toggleButton.Position = UDim2.new(0, 110, 0, 0)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Font = Enum.Font.SourceSansBold
toggleButton.TextSize = 18
toggleButton.Parent = frame

-- State variable
local antiAFKEnabled = false
local antiAFKConnection = nil

-- Function to toggle anti-AFK
local function toggleAntiAFK()
    antiAFKEnabled = not antiAFKEnabled
    if antiAFKEnabled then
        -- Change button text
        toggleButton.Text = "ON"
        -- Connect to Idled event
        local player = game:GetService("Players").LocalPlayer
        antiAFKConnection = player.Idled:Connect(function()
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new(0,0))
            end)
        end)
    else
        -- Change button text
        toggleButton.Text = "OFF"
        -- Disconnect event
        if antiAFKConnection then
            antiAFKConnection:Disconnect()
            antiAFKConnection = nil
        end
    end
end

-- Button click event
toggleButton.MouseButton1Click:Connect(toggleAntiAFK)
