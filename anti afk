-- Anti-AFK Logic (VirtualUser - most reliable method)
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
    statusLabel.Text = "🔄 Roblox tried to kick you... Blocked!"
    wait(2)
    statusLabel.Text = "✅ Active - Preventing AFK Kick"
end)

-- FPS Counter
local fps = 0
RunService.RenderStepped:Connect(function()
    fps += 1
end)

spawn(function()
    while true do
        wait(1)
        fpsLabel.Text = "🚀 FPS: " .. fps
        fps = 0
    end
end)

-- Timer
local startTime = tick()
spawn(function()
    while true do
        local elapsed = tick() - startTime
        local hours = math.floor(elapsed / 3600)
        local minutes = math.floor((elapsed % 3600) / 60)
        local seconds = math.floor(elapsed % 60)
        timeLabel.Text = string.format("⏳ Time: %02d:%02d:%02d", hours, minutes, seconds)
        wait(0.5)
    end
end)

-- Ping (approximate - uses a common client-side method)
