local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

-- Create GUI
local gui = Instance.new("ScreenGui")
gui.Name = "MyFeatureUI"
gui.ResetOnSpawn = false
gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 160, 0, 80)
frame.Position = UDim2.new(0.5, -80, 0.5, -40) -- Centered
frame.BackgroundColor3 = Color3.fromRGB(139, 0, 0)
frame.BorderSizePixel = 0
frame.Parent = gui

-- Variables for dragging
local dragging = false
local dragStartPosition
local startPos

-- Helper function to check if a point is within the frame bounds
local function isPointInsideFrame(point)
    local absolutePosition = frame.AbsolutePosition
    local absoluteSize = frame.AbsoluteSize
    return point.X >= absolutePosition.X and point.X <= absolutePosition.X + absoluteSize.X
       and point.Y >= absolutePosition.Y and point.Y <= absolutePosition.Y + absoluteSize.Y
end

-- Handle input began
local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- For touch, check if the touch started inside the frame
        local position = Vector2.new(input.Position.X, input.Position.Y)
        if isPointInsideFrame(position) then
            dragging = true
            dragStartPosition = position
            startPos = frame.Position
        end
    end
end

-- Handle input changed
local function onInputChanged(input)
    if not dragging then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        local currentPosition = Vector2.new(input.Position.X, input.Position.Y)
        local delta = currentPosition - dragStartPosition
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end

-- Handle input ended
local function onInputEnded(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end

UserInputService.InputBegan:Connect(onInputBegan)
UserInputService.InputChanged:Connect(onInputChanged)
UserInputService.InputEnded:Connect(onInputEnded)

