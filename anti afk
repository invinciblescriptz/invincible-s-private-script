local WindUI = require(game:GetService("ReplicatedStorage"):WaitForChild("WindUI")) -- Adjust if needed

local function createDraggableAntiAFKGUI()
    local player = game.Players.LocalPlayer
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "DraggableAntiAFKGUI"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = player:WaitForChild("PlayerGui")
    
    local windUI = WindUI.new(screenGui)
    
    -- Create a small, draggable frame
    local frame = windUI:Create("Frame", {
        Size = UDim2.new(0, 150, 0, 30),
        Position = UDim2.new(0.5, -75, 0, 10),
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BorderSizePixel = 0,
    })
    
    -- Make the frame draggable
    local isDragging = false
    local dragStartPos
    local startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            dragStartPos = input.Position
            startPos = frame.Position
        end
    end)
    
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = false
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartPos
            frame.Position = startPos + UDim2.new(0, delta.X, 0, delta.Y)
        end
    end)
    
    -- Label: "AFK"
    local label = windUI:Create("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        Text = "AFK",
        TextColor3 = Color3.new(1, 1, 1),
        BackgroundTransparency = 1,
        Font = Enum.Font.SourceSansBold,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    label.Parent = frame
    
    -- Optional: Add a "Disable" button
    local disableButton = windUI:Create("TextButton", {
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -30, 0, 0),
        Text = "X",
        TextColor3 = Color3.new(1,1,1),
        BackgroundColor3 = Color3.fromRGB(200, 0, 0),
        Font = Enum.Font.SourceSans,
        TextSize = 12,
    })
    disableButton.Parent = frame
    
    disableButton.MouseButton1Click:Connect(function()
        screenGui:Destroy()
    end)
end

createDraggableAntiAFKGUI()
