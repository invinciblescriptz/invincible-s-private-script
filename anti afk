-- Variables
local afkTime = 0
local isActive = true
local lastUpdate = tick()

-- Proper Anti-AFK (most reliable method)
LocalPlayer.Idled:Connect(function()
	if isActive then
		VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
		wait(0.1)
		VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
	end
end)

-- Main loop for accurate timer
RunService.Heartbeat:Connect(function(deltaTime)
	if isActive then
		afkTime += deltaTime
		
		local seconds = math.floor(afkTime)
		timerLabel.Text = "AFK Timer: " .. seconds .. "s"
	else
		afkTime = 0
		timerLabel.Text = "AFK Timer: 0s"
	end
end)

-- Toggle button functionality
toggleButton.MouseButton1Click:Connect(function()
	isActive = not isActive
	if isActive then
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
		toggleButton.Text = "AFK Protection: ON"
	else
		toggleButton.BackgroundColor3 = Color3.fromRGB(139, 0, 0)
		toggleButton.Text = "AFK Protection: OFF"
	end
end)
