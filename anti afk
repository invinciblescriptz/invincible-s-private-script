-- Load Wind GUI library
local WindGui = loadstring(game:HttpGet("https://raw.githubusercontent.com/wind-libs/wind/main/wind.lua"))()

local window = WindGui:Window("Anti-AFK with Timer")
local toggle = false
local timerDuration = 60 -- default timer in seconds
local timerLabel

local function startAntiAFK()
    toggle = true
    while toggle do
        -- Prevent AFK by simulating user input
        game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.Space, false, game)
        game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.Space, false, game)
        wait(30) -- send input every 30 seconds
    end
end

local function stopAntiAFK()
    toggle = false
end

local function updateTimer()
    local remaining = timerDuration
    while remaining > 0 do
        timerLabel.Text = "Timer: " .. remaining .. "s"
        wait(1)
        remaining = remaining - 1
    end
    timerLabel.Text = "Time's up!"
end

local startButton = window:Button("Start Anti-AFK", startAntiAFK)
local stopButton = window:Button("Stop Anti-AFK", stopAntiAFK)

local timerSlider = window:Slider("Set Timer (seconds)", 10, 600, function(value)
    timerDuration = value
end)

timerLabel = window:Label("Timer: 0s")

local function runTimer()
    updateTimer()
end

local runTimerButton = window:Button("Start Timer", runTimer)
