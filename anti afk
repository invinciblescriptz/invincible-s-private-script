local function performAntiAFK()
    local cam = Workspace.CurrentCamera
    local originalCFrame = cam.CFrame
    cam.CFrame = cam.CFrame * CFrame.new(0, 0.1, 0)
    wait(0.1)
    cam.CFrame = originalCFrame
end

local function startAntiAFK()
    -- Create label if doesn't exist
    if not timerLabel then
        timerLabel = farmingTab:AddLabel("Anti-AFK Timer: 0s")
        timerLabel.TextSize = 14
    end
    timerLabel.Text = "Anti-AFK Timer: 0s"
    local startTime = os.clock()

    -- Start updating every frame
    antiAfkConn = RunService.Heartbeat:Connect(function()
        if not states.AntiAFK then return end
        if os.clock() - startTime >= 300 then -- 5 min
            performAntiAFK()
            startTime = os.clock()
        end
        local elapsed = math.floor(os.clock() - startTime)
        if timerLabel then
            timerLabel.Text = "Anti-AFK Timer: " .. elapsed .. "s"
        end
    end)
end

local function stopAntiAFK()
    if antiAfkConn then
        antiAfkConn:Disconnect()
        antiAfkConn = nil
    end
    if timerLabel then
        timerLabel.Text = "Anti-AFK Timer: 0s"
    end
end

-- Add the toggle switch for Anti-AFK
farmingTab:AddSwitch("Anti-AFK", false, function(state)
    if state then
        states.AntiAFK = true
        startAntiAFK()
    else
        states.AntiAFK = false
        stopAntiAFK()
    end
end)
