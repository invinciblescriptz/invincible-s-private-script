local ScreenGui = Instance.new("ScreenGui")
local Button = Instance.new("TextButton")

ScreenGui.Parent = game.CoreGui -- or game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.Name = "AntiAFKGui"

Button.Parent = ScreenGui
Button.Size = UDim2.new(0, 200, 0, 50)
Button.Position = UDim2.new(0.5, -100, 0.5, -25)
Button.Text = "Start Anti-AFK"

local isActive = false
local startTime = 0
local connection

local function performAntiAFK()
    print("Anti-AFK action performed")
    -- Add your actual anti-AFK actions here
end

local function toggleAntiAFK()
    if not isActive then
        isActive = true
        startTime = os.time()
        connection = game:GetService("RunService").Heartbeat:Connect(function()
            performAntiAFK()
        end)
        Button.Text = "Stop Anti-AFK"
    else
        isActive = false
        if connection then
            connection:Disconnect()
        end
        local duration = os.time() - startTime
        print("Stopped. Duration: " .. duration .. " seconds.")
        Button.Text = "Start Anti-AFK"
    end
end

Button.MouseButton1Click:Connect(toggleAntiAFK)
