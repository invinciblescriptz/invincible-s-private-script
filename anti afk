local WindUI = require(game.ReplicatedStorage:WaitForChild("WindUI")) -- Adjust the path as needed
local RunService = game:GetService("RunService")

local antiAFKFrame = WindUI:CreateFrame({
    Size = UDim2.new(0, 200, 0, 50),
    Position = UDim2.new(0.5, -100, 0, 10),
    BackgroundColor3 = Color3.new(0, 0, 0),
    BorderSizePixel = 0,
    Transparency = 0.5,
})

local timerLabel = WindUI:CreateLabel({
    Parent = antiAFKFrame,
    Text = "AFK Timer: 0s",
    Size = UDim2.new(1, 0, 1, 0),
    TextColor3 = Color3.new(1, 1, 1),
    TextScaled = true,
})

local afkTime = 0
local lastActivityTime = tick()

-- Function to reset timer on user activity
local function resetTimer()
    lastActivityTime = tick()
end

-- Detect user input
game:GetService("UserInputService").InputBegan:Connect(function()
    resetTimer()
end)

-- Update loop
RunService.Heartbeat:Connect(function()
    local elapsed = tick() - lastActivityTime
    afkTime = math.floor(elapsed)
    timerLabel.Text = "AFK Timer: " .. afkTime .. "s"
end)
