local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Create main GUI
local gui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
gui.Name = "MyFeatureUI"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 160, 0, 160)
frame.Position = UDim2.new(0.5, -80, 0.5, -80) -- Centered
frame.BackgroundColor3 = Color3.fromRGB(139, 0, 0)
frame.BorderSizePixel = 0

-- Make draggable
local function makeDraggable(f)
    local dragging = false
    local dragStart, startPos
    f.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = f.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            f.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

makeDraggable(frame)

-- Add a larger timer label
local timerLabel = Instance.new("TextLabel", frame)
timerLabel.Size = UDim2.new(1, -10, 0, 40) -- Make it bigger
timerLabel.Position = UDim2.new(0, 5, 0, 5)
timerLabel.BackgroundTransparency = 1
timerLabel.TextColor3 = Color3.new(1, 1, 1)
timerLabel.TextSize = 20 -- Larger text size
timerLabel.Font = Enum.Font.SourceSansBold
timerLabel.Text = "AFK Timer: 0s"

-- Anti-AFK variables
local afkTime = 0
local isActive = true -- Auto turn on

-- Function to simulate activity
local function simulateActivity()
    -- Simulate a small movement or input to prevent AFK
    UserInputService:SetKeyDown(Enum.KeyCode.Space, true)
    wait(0.1)
    UserInputService:SetKeyUp(Enum.KeyCode.Space, true)
end

-- Main loop to update timer and simulate activity
RunService.Heartbeat:Connect(function()
    if isActive then
        afkTime = afkTime + RunService.Heartbeat -- Increment based on heartbeat

        -- Every second, update the timer label
        local seconds = math.floor(afkTime)
        if seconds ~= math.floor(afkTime - RunService.Heartbeat) then
            timerLabel.Text = "AFK Timer: " .. seconds .. "s"
        end

        -- Every 5 seconds, simulate activity
        if seconds % 5 == 0 then
            simulateActivity()
        end
    else
        -- When turned off, reset timer display
        timerLabel.Text = "AFK Timer: 0s"
    end
end)
