local antiAFKActive = false
local timerConnection
local startTime = 0
local timerLabel -- to hold the label object for updating

local function performAntiAFK()
    -- Move camera slightly to simulate activity
    local camera = workspace.CurrentCamera
    local originalCFrame = camera.CFrame
    camera.CFrame = camera.CFrame * CFrame.new(0, 0.1, 0)
    wait(0.1)
    camera.CFrame = originalCFrame
end

local function startAntiAFK()
    startTime = os.clock()
    timerLabel:Set("Anti-AFK Timer: 0s")
    local start = os.clock()

    timerConnection = game:GetService("RunService").Heartbeat:Connect(function()
        -- Every 300 seconds (5 minutes), perform anti-AFK action
        if os.clock() - start >= 300 then
            performAntiAFK()
            start = os.clock()
        end
        -- Update timer label
        local elapsed = math.floor(os.clock() - start)
        timerLabel:Set("Anti-AFK Timer: " .. elapsed .. "s")
    end)
end

local function stopAntiAFK()
    if timerConnection then
        timerConnection:Disconnect()
        timerConnection = nil
    end
end

exampleTab:AddSwitch("Anti-AFK", false, function(state)
    if state then
        -- When toggled ON
        antiAFKActive = true
        startAntiAFK()
        -- Create or get existing label for timer
        if not timerLabel then
            timerLabel = farmingTab:AddLabel("Anti-AFK Timer: 0s")
        end
    else
        -- When toggled OFF
        antiAFKActive = false
        stopAntiAFK()
    end
end)
