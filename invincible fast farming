-- Auto eat Protein Egg short function
local autoEatEgg30 = false
local function eatProteinEggShort()
    local player = game.Players.LocalPlayer
    local backpack = player:WaitForChild("Backpack")
    local character = player.Character or player.CharacterAdded:Wait()
    local egg = backpack:FindFirstChild("Protein Egg")
    if egg then
        egg.Parent = character
        pcall(function()
            egg:Activate()
        end)
        print("[AutoEgg] Protein Egg consumido.")
    else
        warn("[AutoEgg] No Protein Egg in Backpack.")
    end
end

task.spawn(function()
    while true do
        if autoEatEgg30 then
            eatProteinEggShort()
            task.wait(1800)
        else
            task.wait(1)
        end
    end
end)

