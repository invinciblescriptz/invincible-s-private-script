local PaceDisplay = TimerSection:AddLabel("Pace: 0K / Hour | 0K / Day | 0M / Week")
local AvgPaceDisplay = TimerSection:AddLabel("Average Pace: 0K / Hour | 0K / Day | 0M / Week")
local StatsDisplay = TimerSection:AddLabel("Rebirths: 0 | Gained: 0")

local startTime = tick()
local rebirths = 4020000
local gained = 6710

local function formatTime(seconds)
    local d = math.floor(seconds / 86400)
    local h = math.floor((seconds % 86400) / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%dd %dh %02dm %02ds - Rebirthing", d, h, m, s)
end

local function updateTimer()
    local elapsed = tick() - startTime
    TimerDisplay.Text = formatTime(elapsed)

    local pacePerHour = math.floor(8230 + math.random(-200, 200))
    local pacePerDay = math.floor(pacePerHour * 24)
    local pacePerWeek = math.floor(pacePerDay * 7)

    PaceDisplay.Text = string.format("Pace: %.1fK / Hour | %.1fK / Day | %.2fM / Week", pacePerHour/1000, pacePerDay/1000, pacePerWeek/1000000)
    AvgPaceDisplay.Text = string.format("Average Pace: %.1fK / Hour | %.1fK / Day | %.2fM / Week", pacePerHour/1000, pacePerDay/1000 + 0.17, pacePerWeek/1000000)
    StatsDisplay.Text = string.format("Rebirths: %.2fM | Gained: %sK", rebirths/1000000, gained/1000)
end

spawn(function()
    while task.wait(1) do
        if TimerDisplay and TimerDisplay.Parent then
            updateTimer()
        else
            break
        end
    end
end)

