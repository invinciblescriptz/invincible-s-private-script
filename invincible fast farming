-- ==================== AUTO FARM FULL LOOP ====================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Stats = game:GetService("Stats")
local LocalPlayer = Players.LocalPlayer

local PET_NAME = "Swift Samurai"
local ROCK_NAME = "Rock5M"
local PROTEIN_EGG_NAME = "ProteinEgg"
local PROTEIN_EGG_INTERVAL = 1800
local REPS_PER_CYCLE = 185
local REP_DELAY = 0.01
local ROCK_INTERVAL = 1
local MAX_PING = 1100

local HumanoidRootPart = nil
local lastProteinEggTime = 0
local lastRockTime = 0
local RockRef = workspace:FindFirstChild(ROCK_NAME)

local function getPing()
    local s, p = pcall(function() return Stats.Network.ServerStatsItem["Data Ping"]:GetValue() end)
    return s and p or 999
end

local function updateCharacterRefs()
    if not LocalPlayer.Character then LocalPlayer.Character = LocalPlayer.CharacterAdded:Wait() end
    HumanoidRootPart = LocalPlayer.Character:WaitForChild("HumanoidRootPart", 5)
end

local function equipPet()
    local pf = LocalPlayer:FindFirstChild("petsFolder")
    if pf and pf:FindFirstChild("Unique") then
        for _, pet in pairs(pf.Unique:GetChildren()) do
            if pet.Name == PET_NAME then
                ReplicatedStorage.rEvents.equipPetEvent:FireServer("equipPet", pet)
                break
            end
        end
    end
end

local function eatProteinEgg()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, item in pairs(bp:GetChildren()) do
            if item.Name == PROTEIN_EGG_NAME then
                ReplicatedStorage.rEvents.eatEvent:FireServer("eat", item)
                break
            end
        end
    end
end

local function hitRock()
    if not RockRef or not RockRef.Parent then RockRef = workspace:FindFirstChild(ROCK_NAME) end
    if RockRef and HumanoidRootPart then
        HumanoidRootPart.CFrame = RockRef.CFrame * CFrame.new(0, 0, -5)
        ReplicatedStorage.rEvents.hitEvent:FireServer("hit", RockRef)
    end
end

if not getgenv()._AutoRepFarmLoop then
    getgenv()._AutoRepFarmLoop = true
    task.spawn(function()
        updateCharacterRefs()
        equipPet()
        lastProteinEggTime = tick()
        lastRockTime = tick()
        while true do
            if getgenv()._AutoRepFarmEnabled then
                if getPing() > MAX_PING then
                    task.wait(5)
                else
                    if LocalPlayer:FindFirstChild("muscleEvent") then
                        for i = 1, REPS_PER_CYCLE do
                            LocalPlayer.muscleEvent:FireServer("rep")
                        end
                    end
                    if tick() - lastProteinEggTime >= PROTEIN_EGG_INTERVAL then
                        eatProteinEgg()
                        lastProteinEggTime = tick()
                    end
                    if tick() - lastRockTime >= ROCK_INTERVAL then
                        hitRock()
                        lastRockTime = tick()
                    end
                    task.wait(REP_DELAY)
                end
            else
                task.wait(1)
            end
        end
    end)
end

-- Separate Eat Egg Loop
task.spawn(function()
    while true do
        if autoEatEnabled then
            local bp = LocalPlayer:WaitForChild("Backpack")
            local egg = bp:FindFirstChild("Protein Egg") or bp:FindFirstChild("ProteinEgg")
            if egg then
                local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                egg.Parent = char
                pcall(function() egg:Activate() end)
            end
            task.wait(1800)
        else
            task.wait(1)
        end
    end
end)

-- ==================== REBIRTH TAB ====================
RebirthTab:AddToggle("Fast Rebirths", "Auto rebirth loop", false, function(state)
    getgenv().AutoFarming = state
    if state then
        task.spawn(function()
            local a = ReplicatedStorage
            local c = LocalPlayer
            local function equipPetByName(name)
                local folder = c:FindFirstChild("petsFolder")
                if not folder then return end
                for _, f in pairs(folder:GetChildren()) do
                    if f:IsA("Folder") then
                        for _, pet in pairs(f:GetChildren()) do
                            if pet.Name == name then
                                a.rEvents.equipPetEvent:FireServer("equipPet", pet)
                                return
                            end
                        end
                    end
                end
            end
            local function unequipAllPets()
                local f = c:FindFirstChild("petsFolder")
                if not f then return end
                for _, folder in pairs(f:GetChildren()) do
                    if folder:IsA("Folder") then
                        for _, pet in pairs(folder:GetChildren()) do
                            a.rEvents.equipPetEvent:FireServer("unequipPet", pet)
                        end
                    end
                end
                task.wait(0.1)
            end
            local function getGolden()
                local g = c:FindFirstChild("ultimatesFolder")
                return g and g:FindFirstChild("Golden Rebirth") and g["Golden Rebirth"].Value or 0
            end
            local function getRequiredStrength()
                local rb = c.leaderstats.Rebirths.Value
                local base = 10000 + (5000 * rb)
                local golden = getGolden()
                if golden >= 1 and golden <= 5 then base = base * (1 - golden * 0.1) end
                return math.floor(base)
            end

            while getgenv().AutoFarming do
                local req = getRequiredStrength()
                unequipAllPets()
                equipPetByName("Swift Samurai")
                while c.leaderstats.Strength.Value < req and getgenv().AutoFarming do
                    for _ = 1, 10 do
                        if c:FindFirstChild("muscleEvent") then c.muscleEvent:FireServer("rep") end
                    end
                    task.wait()
                end
                if getgenv().AutoFarming then
                    unequipAllPets()
                    equipPetByName("Tribal Overlord")
                    local old = c.leaderstats.Rebirths.Value
                    repeat
                        a.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                        task.wait(0.1)
                    until c.leaderstats.Rebirths.Value > old or not getgenv().AutoFarming
                end
                task.wait(0.5)
            end
        end)
    end
end)

