-- ==================== LIVE UPDATER ====================
local startTime = tick()
local rebirths = 4020000 -- example starting values
local gained = 6710

local function formatTime(seconds)
    local d = math.floor(seconds / 86400)
    local h = math.floor((seconds % 86400) / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%dd %dh %02dm %02ds - Rebirthing", d, h, m, s)
end

local function updateTimer()
    local elapsed = tick() - startTime
    TimerDisplay.Text = formatTime(elapsed)

    -- Fake pace calculation (replace with real data)
    local pacePerHour = math.floor(8230 + math.random(-200, 200))
    local pacePerDay = math.floor(pacePerHour * 24)
    local pacePerWeek = math.floor(pacePerDay * 7)

    PaceDisplay.Text = string.format("Pace: %.2fK / Hour | %.2fK / Day | %.2fM / Week",
        pacePerHour / 1000, pacePerDay / 1000, pacePerWeek / 1000000)

    AvgPaceDisplay.Text = string.format("Average Pace: %.2fK / Hour | %.2fK / Day | %.2fM / Week",
        pacePerHour / 1000, pacePerDay / 1000 + 0.17, pacePerWeek / 1000000)

    StatsDisplay.Text = string.format("Rebirths: %.2fM | Gained: %.2fK",
        rebirths / 1000000, gained / 1000)
end

-- Run updater every second
spawn(function()
    while wait(1) do
        if TimerDisplay and TimerDisplay.Parent then
            updateTimer()
        else
            break
        end
    end
end)

