--// Load UI
local ScriptLibrary = loadstring(game:HttpGet("https://raw.githubusercontent.com/p4020854-hub/Lb/refs/heads/main/X", true))()

--// Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Stats = game:GetService("Stats")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer

--// Window
local window = ScriptLibrary:AddWindow(
    string.format("Genesis Hub | Hello %s", LocalPlayer.DisplayName),
    {
        ["min_size"] = Vector2.new(400, 870),
        ["can_resize"] = true,
        ["main_color"] = Color3.fromRGB(0, 0, 0)
    }
)

--// ================= STATE =================
local State = {
    AutoFarm = false,
    AutoRebirth = false,
    AutoEgg = false,
    AutoSpin = false,

    Character = nil,
    HRP = nil,
    Rock = nil,

    LastRock = 0,
    LastEgg = 0,

    StartTime = tick(),
    RebirthStart = 0
}

--// ================= CONFIG =================
local CONFIG = {
    PET = "Swift Samurai",
    REBIRTH_PET = "Tribal Overlord",
    ROCK = "Rock5M",
    EGG = "ProteinEgg",

    REPS = 120,
    REP_DELAY = 0.03,
    ROCK_DELAY = 1,
    EGG_DELAY = 1800,
    MAX_PING = 1000
}

--// ================= CHARACTER =================
local function updateCharacter()
    State.Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    State.HRP = State.Character:WaitForChild("HumanoidRootPart")
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    updateCharacter()
end)

updateCharacter()

--// ================= HELPERS =================
local function getPing()
    local ok, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    return ok and ping or 999
end

local function getRock()
    if not State.Rock or not State.Rock.Parent then
        State.Rock = workspace:FindFirstChild(CONFIG.ROCK)
    end
    return State.Rock
end

local function equipPet(name)
    local folder = LocalPlayer:FindFirstChild("petsFolder")
    if not folder then return end

    for _, sub in pairs(folder:GetChildren()) do
        if sub:IsA("Folder") then
            for _, pet in pairs(sub:GetChildren()) do
                if pet.Name == name then
                    ReplicatedStorage.rEvents.equipPetEvent:FireServer("equipPet", pet)
                    return
                end
            end
        end
    end
end

local function unequipPets()
    local folder = LocalPlayer:FindFirstChild("petsFolder")
    if not folder then return end

    for _, sub in pairs(folder:GetChildren()) do
        if sub:IsA("Folder") then
            for _, pet in pairs(sub:GetChildren()) do
                ReplicatedStorage.rEvents.equipPetEvent:FireServer("unequipPet", pet)
            end
        end
    end
end

local function doReps(amount)
    if LocalPlayer:FindFirstChild("muscleEvent") then
        for _ = 1, amount do
            LocalPlayer.muscleEvent:FireServer("rep")
        end
    end
end

local function hitRock()
    local rock = getRock()
    if rock and State.HRP then
        State.HRP.CFrame = rock.CFrame * CFrame.new(0, 0, -5)
        ReplicatedStorage.rEvents.hitEvent:FireServer("hit", rock)
    end
end

local function eatEgg()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if not bp then return end

    local egg = bp:FindFirstChild(CONFIG.EGG)
    if egg then
        egg.Parent = State.Character
        pcall(function() egg:Activate() end)
    end
end

--// ================= TIMER UI =================
local FastTab = window:AddTab("Fast Farming")

local TimerSection = FastTab:AddSection("⏱️ Fast Farm Timer")
TimerSection:AddLabel("Infinite | Private | Farming")

local TimerLabel = TimerSection:AddLabel("Time: 0d 0h 00m 00s")
local PaceLabel = TimerSection:AddLabel("Pace: Calculating...")
local StatsLabel = TimerSection:AddLabel("Rebirths: 0 | Gained: 0")

task.spawn(function()
    while true do
        local elapsed = tick() - State.StartTime

        local d = math.floor(elapsed / 86400)
        local h = math.floor((elapsed % 86400) / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = math.floor(elapsed % 60)

        TimerLabel:UpdateLabel(string.format("Time: %dd %dh %02dm %02ds", d, h, m, s))

        local stats = LocalPlayer:FindFirstChild("leaderstats")
        if stats and stats:FindFirstChild("Rebirths") then
            local current = stats.Rebirths.Value
            if State.RebirthStart == 0 then
                State.RebirthStart = current
            end

            local gained = current - State.RebirthStart
            local perHour = gained / (elapsed / 3600 + 0.001)

            PaceLabel:UpdateLabel(string.format("Pace: %.1f rebirths/hour", perHour))
            StatsLabel:UpdateLabel(string.format("Rebirths: %d | Gained: %d", current, gained))
        end

        task.wait(1)
    end
end)

--// ================= FEATURES =================

FastTab:AddToggle("Auto Farm", "Auto reps + rock", false, function(v)
    State.AutoFarm = v
end)

FastTab:AddToggle("Auto Egg", "Eat egg every 30 min", false, function(v)
    State.AutoEgg = v
end)

FastTab:AddButton("Hide Frames", "", function()
    for _, obj in pairs(ReplicatedStorage:GetChildren()) do
        if obj:IsA("Frame") then
            obj.Visible = false
        end
    end
end)

--// ================= FARM LOOP =================
task.spawn(function()
    while true do
        if State.AutoFarm then
            if getPing() < CONFIG.MAX_PING then
                doReps(CONFIG.REPS)

                if tick() - State.LastRock > CONFIG.ROCK_DELAY then
                    hitRock()
                    State.LastRock = tick()
                end

                if State.AutoEgg and tick() - State.LastEgg > CONFIG.EGG_DELAY then
                    eatEgg()
                    State.LastEgg = tick()
                end

                task.wait(CONFIG.REP_DELAY)
            else
                task.wait(2)
            end
        else
            task.wait(1)
        end
    end
end)

--// ================= REBIRTH =================
local RebirthTab = window:AddTab("Fast Rebirth")

RebirthTab:AddToggle("Auto Rebirth", "", false, function(v)
    State.AutoRebirth = v
end)

task.spawn(function()
    while true do
        if State.AutoRebirth then
            local stats = LocalPlayer:FindFirstChild("leaderstats")
            if stats then
                local strength = stats:FindFirstChild("Strength")
                local rebirths = stats:FindFirstChild("Rebirths")

                if strength and rebirths then
                    unequipPets()
                    equipPet(CONFIG.PET)

                    local required = 10000 + (5000 * rebirths.Value)

                    while strength.Value < required and State.AutoRebirth do
                        doReps(20)
                        task.wait()
                    end

                    if State.AutoRebirth then
                        unequipPets()
                        equipPet(CONFIG.REBIRTH_PET)

                        ReplicatedStorage.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                        task.wait(0.5)
                    end
                end
            end
        else
            task.wait(1)
        end
    end
end)

--// ================= EXTRA =================

RebirthTab:AddToggle("Lock Position", "", false, function(v)
    if v then
        local pos = State.HRP.CFrame
        State.Lock = RunService.Heartbeat:Connect(function()
            if State.HRP then
                State.HRP.CFrame = pos
            end
        end)
    else
        if State.Lock then
            State.Lock:Disconnect()
            State.Lock = nil
        end
    end
end)

RebirthTab:AddButton("Set Size 1", "", function()
    ReplicatedStorage.rEvents.changeSpeedSizeRemote:InvokeServer("changeSize", 1)
end)

RebirthTab:AddButton("Anti Lag", "", function()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
    Lighting.GlobalShadows = false
    Lighting.Brightness = 0
end)

RebirthTab:AddToggle("Auto Spin", "", false, function(v)
