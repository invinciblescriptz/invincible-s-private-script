local PaceLabel = TimerSection:AddLabel("Pace: 0K / Hour | 0K / Day | 0M / Week")
local AvgPaceLabel = TimerSection:AddLabel("Average Pace: 0K / Hour | 0K / Day | 0M / Week")
local StatsLabel = TimerSection:AddLabel("Rebirths: 0 | Gained: 0")

local startTime = tick()
spawn(function()
    while task.wait(1) do
        local elapsed = tick() - startTime
        local d = math.floor(elapsed / 86400)
        local h = math.floor((elapsed % 86400) / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = math.floor(elapsed % 60)
        
        TimerLabel:UpdateLabel(string.format("Time: %dd %dh %02dm %02ds - Rebirthing", d, h, m, s))
        
